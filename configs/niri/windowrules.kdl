// --- Global Geometry ---
window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
}

// --- Specific App Geometry (GNOME Apps) ---
// Keeps native GNOME apps looking consistent with their own HIG
window-rule {
    match app-id=r#"^org\.gnome\."#
    draw-border-with-background false
    geometry-corner-radius 12
}

// --- Terminal & Dev Tool Cleanup ---
// Prevents double-borders or background bleed on transparent terminals
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    match app-id="Alacritty"
    match app-id="kitty"
    match app-id="com.mitchellh.ghostty"
    match app-id="dev.zed.Zed"     // Your Go/Python editor
    match app-id="floorp"          // Your primary browser
    match app-id="zen"
    draw-border-with-background false
}

// --- Floating Rules ---
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// "Mining Merchant" Fix
// Prevents the game from 'freaking out' by forcing it to float
// We match the Steam App ID (3744080) and the name for safety
// --- Fixed Mining Merchant Rule in windowrules.kdl ---
window-rule {
    match app-id="steam_app_3744080"
    match title="Mining Merchant"
    open-floating true

    // Niri uses these names for both tiling AND floating initial sizes
    default-column-width { fixed 1280; }
    default-window-height { fixed 720; }
}

// --- Aesthetic Dimming ---
// Inactive windows get a slight dim to highlight your Aquamarine focus ring
window-rule {
    match is-active=false
    opacity 0.9
}

// --- Debugging ---
debug {
    honor-xdg-activation-with-invalid-serial
}
